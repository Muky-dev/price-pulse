// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(ulid())
  name         String @unique
  email        String @unique
  passwordHash String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]
  alerts   Alert[]
  offers   Offer[]
}

model Product {
  id         String            @id @default(ulid())
  name       String
  brand      String?
  visibility ProductVisibility @default(PRIVATE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdById String?

  offers Offer[]
  alerts Alert[]
}

model Offer {
  id             String  @id @default(ulid())
  url            String  @unique
  externalId     String?
  scrapeStrategy String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  pricePoints PricePoint[]
  scrapeRuns  ScrapeRun[]
}

model PricePoint {
  id        String   @id @default(ulid())
  price     Decimal
  currency  String   @db.Char(3)
  available Boolean?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String

  @@index([offerId, createdAt])
}

model ScrapeRun {
  id         String    @id @default(ulid())
  success    Boolean
  message    String?
  strategy   String
  startedAt  DateTime
  finishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String

  @@index([offerId, createdAt])
}

model Store {
  id     String @id @default(ulid())
  name   String
  domain String @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  offers Offer[]
}

model Alert {
  id          String    @id @default(ulid())
  threshold   Decimal?
  lastTrigger DateTime?
  type        AlertType

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user      User    @relation(fields: [userId], references: [id])
  userId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

enum AlertType {
  BELOW_PRICE
}

enum ProductVisibility {
  PRIVATE
  SHARED
}
